{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuraSeek",
  "version": "1.0.0",
  "identifier": "com.aienthusiasm.auraseek",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AuraSeek",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "externalBin": [
      "binaries/surreal"
    ],
    "resources": {
      "binaries/opencv_core4.dll": ".",
      "binaries/opencv_imgcodecs4.dll": ".",
      "binaries/opencv_imgproc4.dll": ".",
      "binaries/opencv_dnn4.dll": ".",
      "binaries/opencv_objdetect4.dll": ".",
      "binaries/opencv_highgui4.dll": "."
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libsoup-3.0-0",
          "libglib2.0-0",
          "libgdk-pixbuf-2.0-0",
          "libpango-1.0-0",
          "libcairo2",
          "libgcc-s1",
          "libc6",
          "ffmpeg",
          "libopencv-dev",
          "gstreamer1.0-libav",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-plugins-ugly"
        ]
      }
    }
  }
}