# ──────────────────────────────────────────────────────────────────────────────
# AuraSeek – Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your machine:
#   cp .env.example .env
#
# All values shown are the defaults. Uncomment to override.
# Loaded by: core/config.rs → AppConfig::from_env()
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# PATHS
# ═══════════════════════════════════════════════════════════════════════════════

# Main application data directory
# Linux:   ~/.local/share/auraseek
# Windows: %APPDATA%/auraseek
# macOS:   ~/Library/Application Support/auraseek
# AURASEEK_DATA_DIR=

# Log file path
# Linux:   ~/.local/share/auraseek/auraseek.log
# Windows: %APPDATA%\auraseek\auraseek.log
# macOS:   ~/Library/Logs/auraseek.log
# AURASEEK_LOG_PATH=

# Directory containing AI models, tokenizer, fonts, face_db
# Default: same as AURASEEK_DATA_DIR
# AURASEEK_MODEL_DIR=

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# SQLite database file path
# Default: {AURASEEK_DATA_DIR}/auraseek.sqlite3
# AURASEEK_SQLITE_PATH=

# Qdrant gRPC port used by the Rust client
# Default: 6334
# AURASEEK_QDRANT_PORT=6334

# Enable Qdrant's built-in Web UI dashboard.
# Keep this false for production builds unless you intentionally need local debugging.
# Dashboard URL when enabled: http://127.0.0.1:6333/dashboard
# Default: false
# AURASEEK_QDRANT_DASHBOARD_ENABLED=false

# Qdrant HTTP port used by REST API and the built-in dashboard when enabled
# Dashboard URL: http://127.0.0.1:6333/dashboard
# Default: 6333
# AURASEEK_QDRANT_HTTP_PORT=6333

# Qdrant on-disk storage directory
# Default: {AURASEEK_DATA_DIR}/qdrant_storage
# AURASEEK_QDRANT_STORAGE_DIR=

# ═══════════════════════════════════════════════════════════════════════════════
# AI / MODEL TUNING  (see core/config.rs → AppConfig::from_env)
# ═══════════════════════════════════════════════════════════════════════════════

# YuNet: minimum detection score used at runtime (engine calls set_score_threshold).
# Range: 0.0 – 1.0  Default: 0.93
# AURASEEK_FACE_DETECTION_THRESHOLD=0.93

# Cosine similarity for face identity (DB + session). Same meaning as the old COSINE_THRESHOLD const.
# Prefer this name. Legacy alias: AURASEEK_FACE_THRESHOLD (used only if this variable is unset).
# Range: 0.0 – 1.0  Default: 0.33
# AURASEEK_FACE_IDENTITY_THRESHOLD=0.33
# AURASEEK_FACE_THRESHOLD=0.33

# YuNet: IoU threshold for overlap suppression after score sort.  Default: 0.3
# AURASEEK_FACE_NMS_IOU_THRESHOLD=0.3

# YuNet: max candidates kept (by score) before NMS.  Default: 5000
# AURASEEK_FACE_TOP_K=5000

# YuNet score at `FaceModel::new` matches `AURASEEK_FACE_DETECTION_THRESHOLD` (single knob).

# YOLO object detection confidence (0.0 – 1.0).  Default: 0.25
# AURASEEK_YOLO_CONFIDENCE=0.25

# YOLO NMS IoU (0.0 – 1.0).  Default: 0.45
# AURASEEK_YOLO_IOU=0.45

# Qdrant vector search for text/image/combined.  Default threshold 0.256, limit 10000
# AURASEEK_SEARCH_THRESHOLD=0.256
# AURASEEK_SEARCH_LIMIT=10000

# ffmpeg scene change sensitivity for video ingest (0.0 – 1.0).  Default: 0.11
# AURASEEK_VIDEO_SCENE_THRESHOLD=0.11

# Near-duplicate similarity (0.0 – 1.0). Default: 0.92
# Used for: (1) Qdrant duplicate pairing `score_threshold`
#           (2) cosine skip for consecutive `video_frame` embeddings during video ingest
# Legacy only (read if DUPLICATE unset): AURASEEK_VIDEO_FRAME_DEDUP_COSINE_THRESHOLD
# AURASEEK_DUPLICATE_SCORE_THRESHOLD=0.92

# Duplicate finder: Qdrant scroll page size.  Default: 256
# AURASEEK_DUPLICATE_SCROLL_PAGE_SIZE=256

# Text search query: BPE max token length.  Default: 64
# AURASEEK_TEXT_QUERY_MAX_LEN=64

# SQLite row caps for filter-only search modes.  Defaults: 100 / 100 / 200
# AURASEEK_SEARCH_SQL_LIMIT_OBJECT_FILTER=100
# AURASEEK_SEARCH_SQL_LIMIT_FACE_FILTER=100
# AURASEEK_SEARCH_SQL_LIMIT_FILTER_ONLY=200

# Ingest is intentionally sequential; keep this at 1 unless you know the pipeline.
# AURASEEK_MAX_BATCH_SIZE=1

# ═══════════════════════════════════════════════════════════════════════════════
# FILE WATCHER
# ═══════════════════════════════════════════════════════════════════════════════

# Debounce before batch-ingesting new files (ms).  Default: 2000
# AURASEEK_FS_WATCHER_DEBOUNCE_MS=2000

# Minimum available RAM % (see helpers::available_ram_percent) to run a watcher batch.
# Default: 10.0
# AURASEEK_FS_WATCHER_MIN_RAM_PERCENT=10.0

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════════════════════

# AI inference device: cpu | cuda | auto
# AURASEEK_DEVICE=auto

# ONNX inference threads. Use 1 for strict single-file processing.
# AURASEEK_NUM_THREADS=1

# ═══════════════════════════════════════════════════════════════════════════════
# DEBUG
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug mode: true | false
# AURASEEK_DEBUG=false
