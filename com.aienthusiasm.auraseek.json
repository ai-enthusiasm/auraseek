{
  "app-id": "com.aienthusiasm.auraseek",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.llvm18"
  ],
  "command": "auraseek",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=host",
    "--device=dri"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm18/bin",
    "env": {
      "CARGO_HOME": "/run/build/auraseek/cargo",
      "LIBCLANG_PATH": "/usr/lib/sdk/llvm18/lib"
    }
  },
  "modules": [
    {
      "name": "node",
      "buildsystem": "simple",
      "build-commands": [
        "tar -C /app --strip-components=1 --no-same-owner -xf node-v22.2.0-linux-x64.tar.xz"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://nodejs.org/dist/v22.2.0/node-v22.2.0-linux-x64.tar.xz",
          "sha256": "3544eee9cb1414d6e9003efd56bc807ffb0f4445d2fc383e1df04c3e5e72c91b"
        }
      ]
    },
    {
      "name": "yarn",
      "buildsystem": "simple",
      "build-commands": [
        "tar -C /app --strip-components=1 --no-same-owner -xf yarn-v1.22.22.tar.gz"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/yarnpkg/yarn/releases/download/v1.22.22/yarn-v1.22.22.tar.gz",
          "sha256": "88268464199d1611fcf73ce9c0a6c4d44c7d5363682720d8506f6508addf36a0"
        }
      ]
    },
    {
      "name": "opencv",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_EXAMPLES=OFF",
        "-DBUILD_TESTS=OFF",
        "-DBUILD_PERF_TESTS=OFF",
        "-DBUILD_opencv_apps=OFF",
        "-DBUILD_opencv_js=OFF",
        "-DBUILD_opencv_python2=OFF",
        "-DBUILD_opencv_python3=OFF",
        "-DWITH_EGL=ON",
        "-DWITH_OPENGL=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/opencv/opencv/archive/4.6.0.tar.gz",
          "sha256": "1ec1cba65f9f20fe5a41fda1586e01c70ea0c9a6d7b67c9e13edf0cfe2239277"
        }
      ]
    },
    {
      "name": "auraseek",
      "buildsystem": "simple",
      "build-options": {
        "build-args": ["--share=network"]
      },
      "build-commands": [
        "yarn install --frozen-lockfile",
        "yarn build",
        "cd src-tauri && cargo build --release",
        "install -D src-tauri/target/release/auraseek /app/bin/auraseek",
        "install -D -m 644 src-tauri/icons/128x128.png /app/share/icons/hicolor/128x128/apps/com.aienthusiasm.auraseek.png",
        "install -D -m 644 com.aienthusiasm.auraseek.desktop /app/share/applications/com.aienthusiasm.auraseek.desktop"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}